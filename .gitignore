# ======= 系统 & IDE 忽略 =======
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.bak
*.tmp

# ======= 环境变量与私钥 (绝对不能提交) =======
.env
.env.*
!.env.example

# ======= [Contracts] Foundry 相关 =======
contracts/out/
contracts/cache/
contracts/.gitignore
Contracts/.github/*
# 忽略依赖库的 Git 信息（防止嵌套子模块冲突）
contracts/lib/**/.git
# 部署记录和广播日志 (包含私密地址信息)
contracts/broadcast/
# 静态分析产物
slither-*.json

# ======= [Backend] Go 相关 =======
# 编译后的二进制文件
backend/bin/
backend/main
backend/zenith-api
backend/.gitignore
*.exe
*.exe~
*.dll
*.so
*.dylib
# Go 测试覆盖率产物
*.out
# 配置文件忽略 (保留 example)
backend/internal/config/config.yaml
!backend/internal/config/config.example.yaml

# ======= [Web] 前端相关 =======
web/node_modules/
# 构建产物
web/dist/
web/out/
web/.next/
# 前端环境文件
web/.env.local
web/.env.development.local
web/.env.test.local
web/.env.production.local
# 构建日志
web/npm-debug.log*
web/yarn-debug.log*
web/yarn-error.log*
web/.gitignore

# ======= [Infrastructure] 数据库数据 =======
deploy/etcd/data/
deploy/mysql/data/
deploy/redis/data/
deploy/clickhouse/data/