# ======= 系统 & IDE 杂项 =======
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.bak
*.tmp

# ======= 环境变量与私钥 (严禁提交) =======
.env
.env.*
!.env.example

# ======= [Contracts] Foundry 相关 =======
# 编译产物
contracts/out/
contracts/cache/
# 依赖库的 Git 信息（防止嵌套子模块导致 Git 报错）
contracts/lib/**/.git
# 部署记录和广播日志 (包含部署账号地址)
contracts/broadcast/
# 静态分析产物
slither-*.json

# ======= [Backend] Go 相关 =======
# 编译后的二进制文件
backend/bin/
backend/main
backend/*.exe
backend/*.so
backend/*.dylib
# Go 测试覆盖率产物
*.out
# 配置文件 (保留 example 供他人参考)
backend/etc/*.yaml
!backend/etc/*.example.yaml

# ======= [Web] React/Next.js 相关 =======
# 依赖包
web/node_modules/
# 构建产物
web/.next/
web/out/
web/dist/
# 各种包管理器的日志
web/npm-debug.log*
web/yarn-debug.log*
web/yarn-error.log*
web/pnpm-debug.log*

# ======= [Infrastructure] 容器与数据库数据 =======
deploy/etcd/data/
deploy/mysql/data/
deploy/redis/data/
deploy/clickhouse/data/